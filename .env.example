# ── Database ──────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=parkirpintar
DB_USER=postgres
DB_PASSWORD=secret
DB_MAX_OPEN_CONNS=25
DB_MAX_IDLE_CONNS=5
DB_CONN_TIMEOUT_SECONDS=5

# ── Redis ─────────────────────────────────
REDIS_ADDR=localhost:6379
REDIS_PASSWORD=
REDIS_DB=0

# ── RabbitMQ ──────────────────────────────
RABBITMQ_URL=amqp://guest:guest@localhost:5672/

# ── JWT ───────────────────────────────────
JWT_SECRET=your-secret-key-minimum-32-characters-long
JWT_EXPIRY_HOURS=24

# ── Midtrans ──────────────────────────────
MIDTRANS_SERVER_KEY=SB-Mid-server-xxxx
MIDTRANS_CLIENT_KEY=SB-Mid-client-xxxx
MIDTRANS_ENV=sandbox

# ── Firebase FCM ──────────────────────────
FCM_PROJECT_ID=parkirpintar
FCM_CREDENTIALS_FILE=./config/firebase-credentials.json

# ── AWS SES ───────────────────────────────
AWS_REGION=ap-southeast-1
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key
SES_FROM_EMAIL=noreply@parkirpintar.com

# ── Service Ports ─────────────────────────
GATEWAY_HTTP_PORT=8080
GATEWAY_GRPC_PORT=9000
RESERVATION_GRPC_PORT=9001
BILLING_GRPC_PORT=9002
PAYMENT_GRPC_PORT=9003
PRESENCE_GRPC_PORT=9004
NOTIFICATION_GRPC_PORT=9005

# ── Parking Config ────────────────────────
PARKING_LAT=-6.2088
PARKING_LNG=106.8456
GEOFENCE_RADIUS_METERS=50.0
RESERVATION_HOLD_MINUTES=60

# ── Feature Flags ─────────────────────────
# stub | fcm | ses | all
NOTIFICATION_PROVIDER=stub
# mock | midtrans
PAYMENT_PROVIDER=mock
